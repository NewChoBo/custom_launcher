{
  "version": "1.0",
  "metadata": {
    "title": "Work Mode",
    "description": "Productivity focused layout with development tools",
    "author": "User",
    "created": "2025-07-04",
    "tags": ["work", "productivity", "development"]
  },
  "frame": {
    "ui": {
      "showAppBar": true,
      "colors": {
        "appBarColor": "#2196F3",
        "backgroundColor": "#f5f5f5"
      },
      "opacity": {
        "appBarOpacity": 0.9,
        "backgroundOpacity": 0.95
      }
    },
    "window": {
      "size": {
        "windowWidth": "90%",
        "windowHeight": "70%"
      },
      "position": {
        "horizontalPosition": "center",
        "verticalPosition": "center"
      },
      "behavior": {
        "windowLevel": "normal",
        "skipTaskbar": false
      }
    },
    "system": {
      "monitorIndex": 0
    }
  },
  "layout": {
    "type": "column",
    "spacing": 20,
    "padding": { "top": 24, "bottom": 24, "left": 24, "right": 24 },
    "children": [
      {
        "type": "container",
        "width": "fill",
        "height": 80,
        "decoration": {
          "color": "#E8F5E8",
          "borderRadius": 12
        },
        "padding": { "all": 20 },
        "child": {
          "type": "text",
          "text": "Productivity Workspace",
          "style": {
            "fontSize": 20,
            "fontWeight": "bold",
            "color": "#2E7D32"
          },
          "textAlign": "center"
        }
      },
      {
        "type": "row",
        "spacing": 16,
        "children": [
          {
            "type": "launcher",
            "id": "vscode_work",
            "launcherRef": "vscode",
            "overrides": {
              "displayName": "VS Code",
              "imageType": "large",
              "action": "newwindow"
            },
            "position": {
              "width": 100,
              "height": 100,
              "flex": 1
            },
            "style": {
              "backgroundColor": "#007ACC",
              "borderRadius": 12,
              "elevation": 4
            }
          },
          {
            "type": "launcher",
            "id": "chrome_work",
            "launcherRef": "chrome",
            "overrides": {
              "displayName": "Chrome",
              "imageType": "large",
              "action": "newwindow"
            },
            "position": {
              "width": 100,
              "height": 100,
              "flex": 1
            },
            "style": {
              "backgroundColor": "#4285f4",
              "borderRadius": 12,
              "elevation": 4
            }
          },
          {
            "type": "launcher",
            "id": "explorer_work",
            "launcherRef": "explorer",
            "overrides": {
              "displayName": "Explorer",
              "imageType": "large",
              "action": "documents"
            },
            "position": {
              "width": 100,
              "height": 100,
              "flex": 1
            },
            "style": {
              "backgroundColor": "#4CAF50",
              "borderRadius": 12,
              "elevation": 4
            }
          }
        ]
      },
      {
        "type": "row",
        "spacing": 16,
        "children": [
          {
            "type": "launcher",
            "id": "discord_work",
            "launcherRef": "discord",
            "overrides": {
              "displayName": "Discord",
              "imageType": "default",
              "action": "default"
            },
            "position": {
              "width": 80,
              "height": 80,
              "flex": 1
            },
            "style": {
              "backgroundColor": "#5865F2",
              "borderRadius": 10,
              "elevation": 3
            }
          },
          {
            "type": "launcher",
            "id": "calculator_work",
            "launcherRef": "calculator",
            "overrides": {
              "displayName": "Calculator",
              "imageType": "default",
              "action": "default"
            },
            "position": {
              "width": 80,
              "height": 80,
              "flex": 1
            },
            "style": {
              "backgroundColor": "#FF9800",
              "borderRadius": 10,
              "elevation": 3
            }
          }
        ]
      }
    ]
  },
  "globalSettings": {
    "theme": "light",
    "animations": true,
    "autoHide": false,
    "defaultImageType": "large",
    "defaultActionType": "default"
  }
}
